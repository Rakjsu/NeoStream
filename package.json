{
  "name": "neostream-iptv",
  "productName": "NeoStream IPTV",
  "private": true,
  "version": "4.42.0",
  "description": "Player IPTV completo: TV ao vivo com guia EPG, catch-up e DVR (gravação manual e agendada), filmes e séries com metadados TMDB e trailers, multi-view 2x2, zapping, perfis com controle parental, cast DLNA/AirPlay, downloads offline, MPV opcional, gamepad e auto-update",
  "author": "Rakjsu",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node build/generate-installer-images.js && tsc -b && vite build && electron-builder",
    "build:win": "node build/generate-installer-images.js && tsc -b && vite build && electron-builder --win",
    "build:mac": "node build/generate-installer-images.js && tsc -b && vite build && electron-builder --mac",
    "build:linux": "node build/generate-installer-images.js && tsc -b && vite build && electron-builder --linux",
    "build:installer-images": "node build/generate-installer-images.js",
    "build:custom-installer": "node build/build-custom-installer.cjs",
    "dev:installer-shell": "electron installer-shell --preview",
    "package:win": "vite build && npx @electron/packager . \"NeoStream IPTV\" --platform=win32 --arch=x64 --out=release --overwrite --asar --executable-name=\"NeoStream IPTV\" --icon=public/app-icon.png",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:build": "vite build && playwright test"
  },
  "dependencies": {
    "@vidstack/react": "^1.12.13",
    "axios": "^1.13.2",
    "bonjour-service": "^1.4.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.8",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "ffmpeg-static": "^5.3.0",
    "hls.js": "^1.6.15",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^1.25.0",
    "node-fetch": "^3.3.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.9.6",
    "tailwind-merge": "^3.4.0",
    "vidstack": "^1.12.13"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@emnapi/wasi-threads": "^2.0.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.22",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.20",
    "tailwindcss": "^4.1.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^4.1.6"
  },
  "build": {
    "appId": "com.rakjsu.neostream",
    "productName": "NeoStream IPTV",
    "afterPack": "./build/afterPack.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "node_modules",
      "package.json",
      "dev-app-update.yml"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico",
      "signExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "portable": {
      "artifactName": "NeoStream-IPTV-Portable-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Rakjsu",
      "repo": "NeoStream"
    },
    "nsis": {
      "artifactName": "NeoStream-IPTV-Setup-${version}.${ext}",
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NeoStream IPTV",
      "include": "build/installer.nsh",
      "installerHeader": "build/installer-header.bmp",
      "installerSidebar": "build/installer-sidebar.bmp",
      "uninstallerSidebar": "build/uninstaller-sidebar.bmp",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
